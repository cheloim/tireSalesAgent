{
  "env": {
    "es2020": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "semi": ["error", "always"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "indent": ["error", 2],
    "comma-dangle": ["error", "never"],
    "no-trailing-spaces": "error",
    "eol-last": "error",
    "prefer-const": "warn",
    "no-var": "error",
    "object-shorthand": "warn",
    "arrow-spacing": ["error", { "before": true, "after": true }],
    "no-multi-spaces": "warn",
    "keyword-spacing": "error",
    "space-before-blocks": "error"
  },
  "ignorePatterns": [
    "node_modules/**",
    "public/imagenes/**",
    "**/*.min.js"
  ]
}